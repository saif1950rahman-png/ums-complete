# ============================================================
# University Management System - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Server
PORT=5000
NODE_ENV=development

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=ums_db

# Session Secret (change this to a long random string in production)
SESSION_SECRET=ums_super_secret_key_change_in_production_2024

# CORS Origin — since Express serves the frontend too, this is the same origin
# Local dev:
CORS_ORIGIN=http://localhost:5000
# Production example (Railway/Render):
# CORS_ORIGIN=https://your-app-name.railway.app
